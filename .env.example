# Google Sheets - Invoice Source (public sheet)
SHEET_ID=your_google_sheet_id
SHEET_GID=your_sheet_gid

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@domain.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=Your Name <your_email@domain.com>

# Admin credentials
ADMIN_USER_1=admin1
ADMIN_PASS_1=your_password
ADMIN_USER_2=admin2
ADMIN_PASS_2=your_password

# JWT Secret
JWT_SECRET=your_strong_secret_key

# Google Service Account (base64 encoded JSON key - used for Sheets API write-back)
GOOGLE_SERVICE_ACCOUNT_JSON_B64=your_base64_encoded_service_account_json

# Google OAuth2 credentials (used for Drive upload - avoids service account quota issue)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_refresh_token

# Google Drive - Sub-folder IDs inside the parent Drive folder
DRIVE_FOLDER_DIAMOND_ID=your_l2_diamond_folder_id
DRIVE_FOLDER_GOLD_ID=your_l2_gold_folder_id

# Tracking Sheet for URL write-back
TRACKING_SHEET_ID=your_tracking_spreadsheet_id
TRACKING_SHEET_DIAMOND_GID=your_diamond_tab_gid
TRACKING_SHEET_GOLD_GID=your_gold_tab_gid
